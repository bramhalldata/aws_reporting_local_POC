{
  "$schema": "../dashboard-definition.schema.json",
  "id": "dlq_operations",
  "title": "DLQ Operations",
  "description": "Monitors DLQ failure rates and site-level breakdowns.",
  "schema_version": "1.0.0",
  "layout": {
    "sections": [
      {
        "id": "kpis",
        "label": "Overview",
        "description": "Failure counts across the last 24 hours and 7 days.",
        "widget_ids": ["failures_24h", "failures_7d"],
        "layout": { "type": "grid" }
      },
      {
        "id": "top_sites_7d",
        "label": "Top Sites — 7 days",
        "description": "Sites ranked by failure volume over the most recent 7-day window.",
        "widget_ids": ["top_sites_7d_table"],
        "layout": { "type": "stack" }
      },
      {
        "id": "trends",
        "label": "Trends",
        "widget_ids": ["failure_trend_chart"],
        "layout": { "type": "stack" }
      },
      {
        "id": "top_sites_30d",
        "label": "Top Sites — 30 days",
        "widget_ids": ["top_sites_30d_table"],
        "layout": { "type": "stack" }
      },
      {
        "id": "exceptions",
        "label": "Exceptions",
        "widget_ids": ["exception_types_table"],
        "layout": { "type": "stack" }
      }
    ]
  },
  "widgets": [
    {
      "id": "failures_24h",
      "preset": "failures_24h_kpi"
    },
    {
      "id": "failures_7d",
      "preset": "failures_7d_kpi"
    },
    {
      "id": "top_sites_7d_table",
      "type": "data_table",
      "title": "Top Sites by Failures — last 7 days",
      "data_source": { "artifact": "summary.json", "field": "top_sites" },
      "layout": { "col": 0, "row": 0, "w": 12, "h": 4 }
    },
    {
      "id": "failure_trend_chart",
      "type": "line_chart",
      "title": "30-Day Failure Trend",
      "data_source": { "artifact": "trend_30d.json", "field": "days" },
      "layout": { "col": 0, "row": 0, "w": 12, "h": 4 }
    },
    {
      "id": "top_sites_30d_table",
      "type": "data_table",
      "title": "Top Sites by Failures — last 30 days",
      "data_source": { "artifact": "top_sites.json", "field": "sites" },
      "layout": { "col": 0, "row": 0, "w": 12, "h": 4 }
    },
    {
      "id": "exception_types_table",
      "type": "exceptions_table",
      "title": "Exceptions by Type — last 7 days",
      "data_source": { "artifact": "exceptions.json", "field": "exceptions" },
      "layout": { "col": 0, "row": 0, "w": 12, "h": 4 }
    }
  ],
  "filters": [
    { "id": "client", "type": "url_param", "param": "client" },
    { "id": "env",    "type": "url_param", "param": "env" }
  ],
  "defaults": {
    "section": "kpis"
  }
}
